			Send_bill_in_mail as "Send bill in mail"
			{
				type =  form
				form = Snacks_Form

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											ticket_html = "";
										ticket_html = ticket_html + "<html>";
										ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Snacks invoice</title></head>";
										ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
										ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
										ticket_html = ticket_html + "<table width='600' style='background:#ffffff;border-radius:10px;padding:25px;'>";
										ticket_html = ticket_html + "<tr><td style='text-align:center;border-bottom:2px dashed #ddd;padding-bottom:15px;'>";
										ticket_html = ticket_html + "<h1 style='margin:0;color:#2c3e50;'>Welcome to ABC snacks</h1>";
										ticket_html = ticket_html + "<p style='color:#777;font-size:14px;'>Thank you for choosing our service !</p>";
										ticket_html = ticket_html + "<span style='background:#27ae60;color:#fff;padding:6px 14px;border-radius:20px;font-size:12px;'>PAID ✅</span>";
										ticket_html = ticket_html + "</td></tr>";
										ticket_html = ticket_html + "<tr><td>";
										ticket_html = ticket_html + "<table width='100%' style='font-size:14px;margin-top:20px;'>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Customer Name</td><td style='padding:10px;'>" + input.Name + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Mail</td><td style='padding:10px;'>" + input.Enter_your_email + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>phone</td><td style='padding:10px;'>" + input.Enter_your_phone_number + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Snacks type</td><td style='padding:10px;'>" + input.Select_the_snacks_type + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Price</td><td style='padding:10px;'>" + input.Price + "</td></tr>";
										ticket_html = ticket_html + "<tr>" + "<td style='padding:10px;color:#555;'>QR code</td>" + "<td style='padding:10px;color:#27ae60;font-weight:bold;'>" + "<img src='https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=" + input.Price + "'style='width:120px;height:120px;'>" + "</td>" + "</tr>";
										ticket_html = ticket_html + "</table>";
										ticket_html = ticket_html + "</td></tr>";
										ticket_html = ticket_html + "</table>";
										ticket_html = ticket_html + "</td></tr></table>";
										ticket_html = ticket_html + "</body></html>";
										sendmail
										[
											from :"manikandan@zentegra.com"
											to :input.Enter_your_email
											cc:"manikandansjobzen@gmail.com"
											reply to :"manikandan@zentegra.com"
											subject :"Welcome to ABC snacks"
											message :ticket_html
										]
						)
					}
				}

			}
		}






