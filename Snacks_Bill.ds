			veg_puffs as "veg puffs"
			{
				type =  form
				form = Snacks_Form

				record event = on add or edit

				on user input of Veg_Puffs
				{
					actions 
					{
						custom deluge script
						(
											if(Veg_Puffs == "Onion puffs")
										{
											input.Price = "49";
										}
										else if(Veg_Puffs == "Potato puffs")
										{
											input.Price = "29";
										}
						)
					}
				}

			}
			Veg_Burger as "Veg Burger"
			{
				type =  form
				form = Snacks_Form

				record event = on add or edit

				on user input of Classic_Burger
				{
					actions 
					{
						custom deluge script
						(
											if(Classic_Burger == "Cheese burger")
										{
											input.Price = "99";
										}
										else if(Classic_Burger == "Patty Burger")
										{
											input.Price = "98";
										}
										else if(Classic_Burger == "Aloo thikki burger")
										{
											input.Price = "97";
										}
										else if(Classic_Burger == "Low fat burger")
										{
											input.Price = "69";
										}
						)
					}
				}

			}
