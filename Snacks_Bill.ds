 application "Snacks Bill"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Asia/Kolkata"
 	time format = "24-hr"
 	forms
	{
		form Snacks_Form
		{
			displayname = "Snacks Form"
			success message = "Snack Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Name
			(
    			type = name
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			Enter_your_email
			(
    			type = email
				displayname = "Enter your email"
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			Enter_your_phone_number
			(
    			type = phonenumber
				displayname = "Enter your phone number"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			Select_the_snacks_type
			(
				type = picklist
				displayname = "Select the snacks type"
				maxchar = 100
				values = {"Veg","Non veg"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Indian_veg
			(
				type = picklist
				displayname = "Indian veg "
				maxchar = 100
				values = {"Pani puri","Momos","Vadapav","Bhel puri","Rasa puri","Samosaa","Masala puri"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Veg_Puffs
			(
				type = picklist
				displayname = "Veg puffs"
				maxchar = 100
				values = {"Onion puffs","Potato puffs"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Classic_Burger
			(
				type = picklist
				displayname = "Classic Burger"
				maxchar = 100
				values = {"Cheese burger","Patty Burger","Aloo thikki burger","Low fat burger"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Cheese_based_veg_burgers
			(
				type = picklist
				displayname = "Cheese based veg burgers "
				maxchar = 100
				values = {"Cheese veg burger","Double cheese veg burger","Cheese corn burger"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Paneer_burgers
			(
				type = picklist
				displayname = "Paneer burgers"
				maxchar = 100
				values = {"Paneer burger","Paneer tikka burger","Crispy paneer burger"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Spicy_Burgers
			(
				type = picklist
				displayname = "Spicy Burgers"
				maxchar = 100
				values = {"Mexican Veg Burger","Peri peri veg burger","Masala veg burger"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			French_burger
			(
				type = picklist
				displayname = "French burger"
				maxchar = 100
				values = {"Spicy french fries","Cheese french fries","Peper french fries"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Veg_Pizza
			(
				type = picklist
				displayname = "Veg Pizza"
				maxchar = 100
				values = {"Paneer pizza","Vegetable puffs","Cheese pizza","Plain pizza"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Indian_Non_veg
			(
				type = picklist
				displayname = "Indian Non veg"
				maxchar = 100
				values = {"Chicken 65","Chicken Lollipop","Chilli chicken","Pepper chicken","Fish fry","Fish pakpoda","Prawn fry","Prawn pakoda","Crap lalipop"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Puffs1
			(
				type = picklist
				displayname = "Puffs"
				maxchar = 100
				values = {"Egg puffs","Chicken puffs","Fish puffs","Mutton puffs"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Burger
			(
				type = picklist
				maxchar = 100
				values = {"Egg burger","Chicken burger","Mutton burger","Chicken cheese burger","Crispy chicken burger"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Pizza1
			(
				type = picklist
				displayname = "Pizza"
				maxchar = 100
				values = {"Egg pizza","Chicken pizza","Crispy chicken pizza","Prawn pizza"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Price
			(
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Veg
		{
			success message = "Veg Added Successfully"
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
	reports
	{
		default list All_Snacks
		{
			displayName = "All Snacks"
			show all rows from Snacks_Form    
			(
				Select_the_snacks_type as "Select the snacks type"
				Classic_Burger as "Classic Burger"
				Cheese_based_veg_burgers as "Cheese based veg burgers "
				Paneer_burgers as "Paneer burgers"
				Spicy_Burgers as "Spicy Burgers"
				French_burger as "French burger"
				Indian_veg as "Indian veg "
				Veg_Puffs as "Veg puffs"
				Veg_Pizza as "Veg Pizza"
				Indian_Non_veg as "Indian Non veg"
				Puffs1 as "Puffs"
				Burger
				Pizza1 as "Pizza"
				Name 
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Enter_your_email as "Enter your email"
				Enter_your_phone_number as "Enter your phone number"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Price
			)
		}
		default list All_Veges
		{
			displayName = "All Veges"
			show all rows from Veg    
		}
	}
	pages
	{
		page Front_view
		{
			displayname = "Front view"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t\n</layout>\n</zml>"
		}
	}


		workflow
		{
		form
		{
			Load_form as "Load form"
			{
				type =  form
				form = Snacks_Form

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Indian_veg;
										hide Veg_Puffs;
										hide Classic_Burger;
										hide Cheese_based_veg_burgers;
										hide Paneer_burgers;
										hide Spicy_Burgers;
										hide French_burger;
										hide Veg_Pizza;
										hide Indian_Non_veg;
										hide Puffs1;
										hide Pizza1;
										hide Burger;
										disable Price;
						)
					}
				}

			}
			New_load as "New load"
			{
				type =  form
				form = Snacks_Form

				record event = on add or edit

				on user input of Select_the_snacks_type
				{
					actions 
					{
						custom deluge script
						(
											if(Select_the_snacks_type == "Veg")
										{
											show Indian_veg;
											show Veg_Puffs;
											show Classic_Burger;
											show Cheese_based_veg_burgers;
											show Paneer_burgers;
											show Spicy_Burgers;
											show French_burger;
											show Veg_Pizza;
										}
										else if(Select_the_snacks_type == "Non veg")
										{
											show Indian_Non_veg;
											show Puffs1;
											show Burger;
											show Pizza1;
										}
										else if(Select_the_snacks_type != "veg" || Select_the_snacks_type != "Non veg")
										{
											hide Indian_veg;
											hide Veg_Puffs;
											hide Classic_Burger;
											hide Cheese_based_veg_burgers;
											hide Paneer_burgers;
											hide Spicy_Burgers;
											hide French_burger;
											hide Veg_Pizza;
											hide Indian_Non_veg;
											hide Puffs1;
											hide Burger;
											hide Pizza1;
										}
						)
					}
				}

			}
			Disable2 as "Disable2"
			{
				type =  form
				form = Snacks_Form

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Price;
						)
					}
				}

			}
			Indian_veg as "Indian veg"
			{
				type =  form
				form = Snacks_Form

				record event = on add or edit

				on user input of Indian_veg
				{
					actions 
					{
						custom deluge script
						(
											if(Indian_veg == "Pani puri")
										{
											input.Price = "35";
										}
										else if(Indian_veg == "Momos")
										{
											input.Price = "49";
										}
										else if(Indian_veg == "Vadapav")
										{
											input.Price = "39";
										}
										else if(Indian_veg == "Bhel puri")
										{
											input.Price = "39";
										}
										else if(Indian_veg == "Rasa puri")
										{
											input.Price = "49";
										}
										else if(Indian_veg == "Samosaa")
										{
											input.Price = "11";
										}
										else if(Indian_veg == "Masala puri")
										{
											input.Price = "35";
										}
						)
					}
				}

			}
